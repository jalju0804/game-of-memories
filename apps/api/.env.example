# API runtime env for AODS or local production-like runs.
# Do not commit real passwords or tokens.
#
# Target DB from the shared Kubernetes namespace:
#   service/aolda-games-haproxy.shared.svc.cluster.local:3306
#
# Important: this target is PXC/MySQL-compatible. The current API code still uses
# the PostgreSQL `pg` driver, so the backend DB adapter must be migrated to MySQL
# before this URL can be used successfully.

NODE_ENV=production
PORT=8080

# Values should come from the shared namespace secrets:
#   secret/aolda-games-secrets or secret/internal-aolda-games
DATABASE_URL=mysql://<db-user>:<db-password>@aolda-games-haproxy.shared.svc.cluster.local:3306/<db-name>

# Browser origin allowed to call the API.
CORS_ORIGIN=https://bear-game.ajou.app

# Player session lifetime.
SESSION_TTL_DAYS=30

# Diagnostics values returned by /api/diagnostics.
API_VERSION=0.1.0
BUILD_SHA=<commit-sha>
