# Web build-time env for Vite.
# This value is baked into the static frontend image at build time.

# Public API origin reachable by the player's browser.
# Local compose example: http://localhost:8080
# AODS example if API has a separate host: https://api.bear-game.ajou.app
# AODS example if API is reverse-proxied under the same host: https://bear-game.ajou.app
VITE_API_BASE_URL=https://<api-origin>
